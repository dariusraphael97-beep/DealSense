# Supabase — get these from supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — get from console.anthropic.com
# Used for AI summary + negotiation scripts.
# If omitted, the app falls back to template-based text.
ANTHROPIC_API_KEY=sk-ant-...

# ── Live Pricing APIs (both optional — app works without them) ──────────────
#
# VinAudit — MOST ACCURATE when a VIN is provided.
# Uses 90-day rolling window of real transaction data (not just listings).
# Sign up at vinaudit.com/market-value-api (~$0.40/lookup, pay-per-use).
# Only called when user enters a VIN.
VINAUDIT_API_KEY=your-vinaudit-key

# MarketCheck — best option when no VIN is available.
# Uses ML price prediction + 4M+ active US listings.
# Sign up at marketcheck.com/api ($50-500/mo depending on volume).
# Called for all analyses when VinAudit is unavailable or no VIN given.
MARKETCHECK_API_KEY=your-marketcheck-key
